import Mathlib.FieldTheory.IntermediateField.Adjoin.Basic
import TauCeti.Algebra.Polynomial.CardRootSetUnion

/-!
# Counting simple intermediate fields generated by a finite set

Mathlib's proof of Hermite's finiteness theorem
`NumberField.finite_of_discr_bdd` reduces bounded-discriminant number fields in a fixed ambient
extension to fields generated by elements of a finite root set. The effective
Hermite--Minkowski target needs the corresponding cardinality step: if the admissible generators
lie in a finite set `T`, then the simple intermediate fields `K⟮x⟯` generated by elements of `T`
are no more numerous than `T`.

This file supplies that elementary injection step, together with the bounded-polynomial-root
specialization used by the EffectiveBounds roadmap's Layer 2 count. The bounded root set itself
is counted in `TauCeti.Algebra.Polynomial.CardRootSetUnion`; here we only pass from roots to the
simple intermediate fields they generate.

## Main results

* `TauCeti.IntermediateField.finite_setOf_exists_mem_eq_adjoin`: simple intermediate fields
  generated by a finite set form a finite set.
* `TauCeti.IntermediateField.ncard_setOf_exists_mem_eq_adjoin_le`: their number is at most the
  number of allowed generators.
* `TauCeti.IntermediateField.ncard_setOf_exists_root_natDegree_le_abs_intCoeff_le`: the
  specialization to roots of integer polynomials of bounded degree and coefficient height.

No formal code is vendored. The proof reuses Mathlib's `IntermediateField.adjoin` API and Tau
Ceti's explicit bounded-polynomial root count.
-/

open Polynomial
open scoped IntermediateField

namespace TauCeti

namespace IntermediateField

variable {K L : Type*} [Field K] [Field L] [Algebra K L]

/-- The simple intermediate fields `K⟮x⟯` generated by elements of a finite set `T` form a
finite set. -/
theorem finite_setOf_exists_mem_eq_adjoin {T : Set L} (hT : T.Finite) :
    {E : IntermediateField K L | ∃ x ∈ T, E = K⟮x⟯}.Finite := by
  convert hT.image (fun x => (K⟮x⟯ : IntermediateField K L)) using 1
  ext E
  constructor
  · rintro ⟨x, hx, rfl⟩
    exact ⟨x, hx, rfl⟩
  · rintro ⟨x, hx, rfl⟩
    exact ⟨x, hx, rfl⟩

/-- The number of simple intermediate fields `K⟮x⟯` generated by elements of a finite set `T`
is at most the number of elements of `T`. Different generators can produce the same field, so this
is the image-cardinality bound rather than an equality. -/
theorem ncard_setOf_exists_mem_eq_adjoin_le {T : Set L} (hT : T.Finite) :
    {E : IntermediateField K L | ∃ x ∈ T, E = K⟮x⟯}.ncard ≤ T.ncard := by
  have hset :
      {E : IntermediateField K L | ∃ x ∈ T, E = K⟮x⟯} =
        (fun x => (K⟮x⟯ : IntermediateField K L)) '' T := by
    ext E
    constructor
    · rintro ⟨x, hx, rfl⟩
      exact ⟨x, hx, rfl⟩
    · rintro ⟨x, hx, rfl⟩
      exact ⟨x, hx, rfl⟩
  rw [hset]
  exact Set.ncard_image_le (f := fun x => (K⟮x⟯ : IntermediateField K L)) hT

variable (A : Type*) [Field A] [Algebra ℚ A] [DecidableEq A]

/-- The simple subfields of an ambient field `A / ℚ` generated by roots of integer polynomials of
degree at most `d` and coefficient height at most `B` number at most
`(2 * B + 1) ^ (d + 1) * d`.

This is the root-to-field counting step used by the effective Hermite--Minkowski target, after
`TauCeti.Polynomial.ncard_biUnion_roots_natDegree_le_abs_intCoeff_le` has counted the possible
generators. -/
theorem ncard_setOf_exists_root_natDegree_le_abs_intCoeff_le (d B : ℕ) :
    {E : IntermediateField ℚ A |
      ∃ x ∈ (⋃ (f : ℤ[X]) (_ : f.natDegree ≤ d ∧ ∀ i, |f.coeff i| ≤ (B : ℤ)),
        (((f.map (algebraMap ℤ A)).roots.toFinset : Set A))), E = ℚ⟮x⟯}.ncard ≤
      (2 * B + 1) ^ (d + 1) * d := by
  classical
  set T : Set A := ⋃ (f : ℤ[X]) (_ : f.natDegree ≤ d ∧ ∀ i, |f.coeff i| ≤ (B : ℤ)),
    (((f.map (algebraMap ℤ A)).roots.toFinset : Set A)) with hTdef
  have hpred : ∀ (f : ℤ[X]) (i : ℕ),
      |f.coeff i| ≤ (B : ℤ) ↔ f.coeff i ∈ Set.Icc (-(B : ℤ)) B := by
    intro f i
    rw [Set.mem_Icc, abs_le]
  have hTfinite : T.Finite := by
    rw [hTdef]
    simpa only [hpred] using
      Polynomial.bUnion_roots_finite (algebraMap ℤ A) d
        (U := Set.Icc (-(B : ℤ)) B) (Set.finite_Icc (-(B : ℤ)) B)
  calc {E : IntermediateField ℚ A | ∃ x ∈ T, E = ℚ⟮x⟯}.ncard
      ≤ T.ncard := ncard_setOf_exists_mem_eq_adjoin_le hTfinite
    _ ≤ (2 * B + 1) ^ (d + 1) * d :=
        TauCeti.Polynomial.ncard_biUnion_roots_natDegree_le_abs_intCoeff_le
          (algebraMap ℤ A) d B

end IntermediateField

end TauCeti
