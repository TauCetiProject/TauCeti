module

public import TauCeti.NumberTheory.Multiquadratic.LegendrePrimeDiscriminants
public import TauCeti.NumberTheory.NumberField.MultiquadraticSplitting

/-!
# Prime-discriminant splitting in multiquadratic fields

The genus-field layer indexes the quadratic factors by prime discriminants `D`, while the
multiquadratic splitting theorem is stated for the corresponding squarefree radicands
`primeDiscriminantRadicand D`. This file records the small bridge between those conventions.

The prime-discriminant convention follows the standard genus-theory convention in Cox's
*Primes of the Form x² + ny²* and Lemmermeyer's *Reciprocity Laws*.

## Main results

* `TauCeti.Multiquadratic.dvd_primeDiscriminant_iff_dvd_radicand`: away from `2`, a prime
  divides a prime discriminant exactly when it divides its squarefree radicand.
* `TauCeti.NumberField.ncard_primesOver_primeDiscriminantRadicands_iff`: the multiquadratic
  splitting law for a field generated by roots of prime-discriminant radicands, stated in
  terms of Legendre symbols of the prime discriminants themselves.
* `TauCeti.NumberField.ncard_primesOver_primeDiscriminantRadicands_iff_congruence`: the same
  law with the prime-discriminant Legendre condition expanded into the existing congruence
  criterion.
-/

public section

open Ideal Module NumberField

namespace TauCeti.Multiquadratic

variable {q : ℕ} [Fact q.Prime]

/-- Away from `2`, divisibility of a prime discriminant is the same as divisibility of its
associated squarefree radicand. In the even-prime cases the two differ by the square factor
`4`; in the odd-prime cases they are equal. -/
theorem dvd_primeDiscriminant_iff_dvd_radicand {D : ℤ}
    (hD : IsPrimeDiscriminant D) (hq : q ≠ 2) :
    (q : ℤ) ∣ D ↔ (q : ℤ) ∣ primeDiscriminantRadicand D := by
  rcases primeDiscriminant_eq_radicand_or_eq_four_mul_radicand hD with h | h
  · constructor
    · intro hd
      rwa [h] at hd
    · intro hr
      rwa [h]
  · refine ⟨fun hd => ?_, fun hr => ?_⟩
    · have hq4r : (q : ℤ) ∣ 4 * primeDiscriminantRadicand D := by
        rwa [h] at hd
      rcases (Nat.prime_iff_prime_int.mp (Fact.out : q.Prime)).dvd_mul.mp hq4r with hq4 | hr
      · have hq4_nat : q ∣ 4 := by exact_mod_cast hq4
        have hq2 : q ∣ 2 :=
          (Fact.out : q.Prime).dvd_of_dvd_pow (by simpa using hq4_nat : q ∣ 2 ^ 2)
        exact False.elim (hq ((Nat.prime_dvd_prime_iff_eq Fact.out Nat.prime_two).mp hq2))
      · exact hr
    · rw [h]
      exact dvd_mul_of_dvd_right hr 4

/-- Away from `2`, an indexed family of prime discriminants and its associated radicands have
the same unramifiedness condition at `q`. -/
theorem forall_not_dvd_primeDiscriminant_iff_radicand {ι : Type*} (D : ι → ℤ)
    (hD : ∀ i, IsPrimeDiscriminant (D i)) (hq : q ≠ 2) :
    (∀ i, ¬ (q : ℤ) ∣ D i) ↔
      ∀ i, ¬ (q : ℤ) ∣ primeDiscriminantRadicand (D i) := by
  refine forall_congr' fun i => ?_
  exact not_congr (dvd_primeDiscriminant_iff_dvd_radicand (hD i) hq)

end TauCeti.Multiquadratic

namespace TauCeti.NumberField

variable {K : Type*} [Field K] [NumberField K]

/-- **Prime-discriminant multiquadratic splitting law.** Let `K` be generated over `ℚ` by
square roots of the radicands attached to a finite family of prime discriminants `D`. For an
odd prime `p` dividing none of the discriminants, `p` splits completely in `K` exactly when
every prime discriminant `D i` is a quadratic residue modulo `p`. -/
theorem ncard_primesOver_primeDiscriminantRadicands_iff {ι : Type*} [Finite ι]
    (D : ι → ℤ) (r : ι → K) (hD : ∀ i, TauCeti.Multiquadratic.IsPrimeDiscriminant (D i))
    (hr : ∀ i, r i ^ 2 =
      algebraMap ℤ K (TauCeti.Multiquadratic.primeDiscriminantRadicand (D i)))
    (htop : IntermediateField.adjoin ℚ (Set.range r) = ⊤)
    {p : ℕ} [Fact p.Prime] (hodd : p ≠ 2) (hcop : ∀ i, ¬ (p : ℤ) ∣ D i) :
    (primesOver (span {(p : ℤ)}) (𝓞 K)).ncard = finrank ℚ K ↔
      ∀ i, legendreSym p (D i) = 1 := by
  have hcop_rad : ∀ i, ¬ (p : ℤ) ∣ TauCeti.Multiquadratic.primeDiscriminantRadicand (D i) :=
    (TauCeti.Multiquadratic.forall_not_dvd_primeDiscriminant_iff_radicand D hD hodd).mp hcop
  exact (ncard_primesOver_multiquadratic_iff
    (d := fun i => TauCeti.Multiquadratic.primeDiscriminantRadicand (D i))
    (r := r) hr htop hodd hcop_rad).trans
      (TauCeti.Multiquadratic.forall_legendreSym_primeDiscriminant_eq_one_iff_radicand
        D hodd).symm

/-- **Prime-discriminant multiquadratic splitting law, congruence form.** This is
`ncard_primesOver_primeDiscriminantRadicands_iff` with the Legendre-symbol condition for each
prime discriminant expanded into the existing congruence criterion. -/
theorem ncard_primesOver_primeDiscriminantRadicands_iff_congruence {ι : Type*} [Finite ι]
    (D : ι → ℤ) (r : ι → K) (hD : ∀ i, TauCeti.Multiquadratic.IsPrimeDiscriminant (D i))
    (hr : ∀ i, r i ^ 2 =
      algebraMap ℤ K (TauCeti.Multiquadratic.primeDiscriminantRadicand (D i)))
    (htop : IntermediateField.adjoin ℚ (Set.range r) = ⊤)
    {q : ℕ} [Fact q.Prime] (hq : q ≠ 2) (hcop : ∀ i, ¬ (q : ℤ) ∣ D i) :
    (primesOver (span {(q : ℤ)}) (𝓞 K)).ncard = finrank ℚ K ↔
      ∀ i,
        (TauCeti.Multiquadratic.IsEvenPrimeDiscriminant (D i) ∧
          (if D i = -4 then q % 4 = 1
          else if D i = 8 then q % 8 = 1 ∨ q % 8 = 7
          else q % 8 = 1 ∨ q % 8 = 3)) ∨
        ∃ p : ℕ, ∃ hp : p.Prime, Odd p ∧
          D i = TauCeti.Multiquadratic.oddPrimeDiscriminant p ∧
          @legendreSym p ⟨hp⟩ (q : ℤ) = 1 := by
  exact (ncard_primesOver_primeDiscriminantRadicands_iff D r hD hr htop hq hcop).trans
    (TauCeti.Multiquadratic.forall_legendreSym_primeDiscriminant_eq_one_iff D hD hq)

end TauCeti.NumberField
