module

public import TauCeti.NumberTheory.Multiquadratic.LegendrePrimeDiscriminantExamples
public import TauCeti.NumberTheory.Multiquadratic.PrimeDiscriminantGaloisGroup
public import Mathlib.Data.Complex.Basic
public import Mathlib.Analysis.Real.Sqrt

/-!
# The degree and Galois group of the `-5` prime-discriminant radicand field

The worked examples in the multiquadratic roadmap identify the genus field for `ℚ(√-5)` as
`ℚ(√-1, √5)`, attached to the prime discriminants `-4` and `5`. This file records the immediate
Layer-0 consequence needed before the actual genus-field comparison: those two
prime-discriminant radicands are square-class independent, so their multiquadratic compositum
over `ℚ` has degree `4`, and its Galois group over `ℚ` has cardinality `4`.

The prime-discriminant convention follows the standard genus-theory convention in Cox's
*Primes of the Form x² + ny²* and Lemmermeyer's *Reciprocity Laws*.

## Main result

* `TauCeti.Multiquadratic.finrank_adjoin_I_sqrt_five`: the worked-example degree
  `[ℚ(i, √5) : ℚ] = 4`.
* `TauCeti.Multiquadratic.card_aut_adjoin_I_sqrt_five`: the worked-example cardinality
  `|Gal(ℚ(i, √5)/ℚ)| = 4`.
-/

public section

open IntermediateField

namespace TauCeti.Multiquadratic

/-- The complex square root data for the two prime discriminants `-4` and `5`: the associated
radicands are `-1` and `5`, with roots `i` and `√5`. -/
private theorem root_neg_four_five_sq (i : Fin 2) :
    (fun i : Fin 2 => ![Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)] i) i ^ 2 =
      algebraMap ℚ ℂ
        (((primeDiscriminantRadicand (negFourFivePrimeDiscriminants i) : ℤ) : ℚ)) := by
  fin_cases i
  · simp [negFourFivePrimeDiscriminants, Complex.I_sq]
  · have h : (((Real.sqrt 5 : ℝ) : ℂ) ^ 2) = (5 : ℂ) := by
      rw [← Complex.ofReal_pow, Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 5)]
      norm_num
    simpa [negFourFivePrimeDiscriminants, primeDiscriminantRadicand] using h

private theorem isPrimeDiscriminant_negFourFivePrimeDiscriminants :
    ∀ i : Fin 2, IsPrimeDiscriminant (negFourFivePrimeDiscriminants i) := by
  intro i
  fin_cases i
  · simp [negFourFivePrimeDiscriminants]
  · have h5 : IsPrimeDiscriminant (5 : ℤ) := by
      simpa [oddPrimeDiscriminant_of_mod_four_eq_one (by norm_num : 5 % 4 = 1)]
        using isPrimeDiscriminant_oddPrimeDiscriminant (p := 5) (by decide) (by decide)
    simpa [negFourFivePrimeDiscriminants] using h5

private theorem negFourFivePrimeDiscriminants_injective :
    Function.Injective negFourFivePrimeDiscriminants := by
  decide

private theorem not_all_even_negFourFivePrimeDiscriminants :
    ¬ ((∃ i : Fin 2, negFourFivePrimeDiscriminants i = -4) ∧
      (∃ i : Fin 2, negFourFivePrimeDiscriminants i = 8) ∧
        (∃ i : Fin 2, negFourFivePrimeDiscriminants i = -8)) := by
  decide

private theorem range_roots_neg_four_five :
    (Set.range fun i : Fin 2 => ![Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)] i)
      = {Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)} := by
  ext x
  simp only [Set.mem_range, Set.mem_insert_iff, Set.mem_singleton_iff]
  constructor
  · intro hx
    rcases hx with ⟨i, rfl⟩
    fin_cases i <;> simp
  · intro hx
    rcases hx with hx | hx
    · exact ⟨0, by simp [hx]⟩
    · exact ⟨1, by simp [hx]⟩

/-- **Worked example: `[ℚ(i, √5) : ℚ] = 4`.** This is the degree of the
multiquadratic field generated by the radicands attached to the prime discriminants `-4` and
`5`, the genus-field generators for `ℚ(√-5)`. -/
theorem finrank_adjoin_I_sqrt_five :
    Module.finrank ℚ
      (adjoin ℚ ({Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)} : Set ℂ) :
        IntermediateField ℚ ℂ)
      = 4 := by
  have h := finrank_adjoin_roots_primeDiscriminantRadicands negFourFivePrimeDiscriminants
    isPrimeDiscriminant_negFourFivePrimeDiscriminants
    negFourFivePrimeDiscriminants_injective not_all_even_negFourFivePrimeDiscriminants
    (fun i : Fin 2 => ![Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)] i)
    root_neg_four_five_sq
  rw [← range_roots_neg_four_five]
  exact h.trans (by norm_num [Nat.card_fin])

/-- **Worked example: `|Gal(ℚ(i, √5)/ℚ)| = 4`.** This is the Galois group of the
multiquadratic field generated by the radicands attached to the prime discriminants `-4` and
`5`, the genus-field generators for `ℚ(√-5)`. -/
theorem card_aut_adjoin_I_sqrt_five :
    Nat.card
      ((adjoin ℚ ({Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)} : Set ℂ) :
          IntermediateField ℚ ℂ)
          ≃ₐ[ℚ]
        (adjoin ℚ ({Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)} : Set ℂ) :
          IntermediateField ℚ ℂ))
      = 4 := by
  have h := card_aut_adjoin_roots_primeDiscriminantRadicands negFourFivePrimeDiscriminants
    isPrimeDiscriminant_negFourFivePrimeDiscriminants
    negFourFivePrimeDiscriminants_injective not_all_even_negFourFivePrimeDiscriminants
    (fun i : Fin 2 => ![Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)] i) root_neg_four_five_sq
  rw [← range_roots_neg_four_five]
  exact h.trans (by norm_num [Nat.card_fin])

end TauCeti.Multiquadratic
