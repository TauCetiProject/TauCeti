module

public import TauCeti.NumberTheory.Multiquadratic.MinusTwentyOneGalois

/-!
# Degree examples for prime-discriminant multiquadratic fields

The worked examples in the multiquadratic roadmap name the genus-field generators for
`ℚ(√-5)` and `ℚ(√-21)`: respectively `ℚ(i, √5)` and `ℚ(i, √-3, √-7)`. Before the later
class-field-theoretic comparison with genus fields, the Layer-0 multiquadratic theory should
record the basic degree facts for these generator lists.

This file packages those two readings of
`TauCeti.Multiquadratic.finrank_adjoin_roots_primeDiscriminantRadicands`. It uses the
prime-discriminant convention from Cox's *Primes of the Form x² + ny²* and Lemmermeyer's
*Reciprocity Laws*, and the square-class independence already proved in
`TauCeti.NumberTheory.Multiquadratic.PrimeDiscriminantIndependence`.

## Main results

* `TauCeti.Multiquadratic.finrank_adjoin_I_sqrt_five`: `[ℚ(i, √5) : ℚ] = 4`.
* `TauCeti.Multiquadratic.finrank_adjoin_I_sqrt_neg_three_sqrt_neg_seven`:
  `[ℚ(i, √-3, √-7) : ℚ] = 8`.
-/

public section

open IntermediateField

namespace TauCeti.Multiquadratic

/-- The prime-discriminant list `[-4, 5]` for the `ℚ(√-5)` genus-field generators. -/
private def negFivePrimeDiscriminants : Fin 2 → ℤ :=
  ![(-4 : ℤ), 5]

/-- The complex square root data for the prime discriminants `-4` and `5`: the associated
radicands are `-1` and `5`, with roots `i` and `√5`. -/
private theorem root_neg_four_five_sq (i : Fin 2) :
    (fun i : Fin 2 => ![Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)] i) i ^ 2 =
      algebraMap ℚ ℂ
        (((primeDiscriminantRadicand (negFivePrimeDiscriminants i) : ℤ) : ℚ)) := by
  fin_cases i
  · simp [negFivePrimeDiscriminants, Complex.I_sq]
  · have h : (((Real.sqrt 5 : ℝ) : ℂ) ^ 2) = (5 : ℂ) := by
      rw [← Complex.ofReal_pow, Real.sq_sqrt (by norm_num : (0 : ℝ) ≤ 5)]
      norm_num
    simpa [negFivePrimeDiscriminants, primeDiscriminantRadicand] using h

private theorem isPrimeDiscriminant_negFivePrimeDiscriminants :
    ∀ i : Fin 2, IsPrimeDiscriminant (negFivePrimeDiscriminants i) := by
  intro i
  fin_cases i
  · simp [negFivePrimeDiscriminants]
  · have h5 : IsPrimeDiscriminant (5 : ℤ) := by
      simpa [oddPrimeDiscriminant_of_mod_four_eq_one (by norm_num : 5 % 4 = 1)]
        using isPrimeDiscriminant_oddPrimeDiscriminant (p := 5) (by decide) (by decide)
    simpa [negFivePrimeDiscriminants] using h5

private theorem injective_negFivePrimeDiscriminants :
    Function.Injective negFivePrimeDiscriminants := by
  decide

private theorem not_all_even_negFivePrimeDiscriminants :
    ¬ ((∃ i : Fin 2, negFivePrimeDiscriminants i = -4) ∧
      (∃ i : Fin 2, negFivePrimeDiscriminants i = 8) ∧
        (∃ i : Fin 2, negFivePrimeDiscriminants i = -8)) := by
  decide

private theorem range_roots_neg_four_five :
    (Set.range fun i : Fin 2 => ![Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)] i)
      = {Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)} := by
  ext x
  simp only [Set.mem_range, Set.mem_insert_iff, Set.mem_singleton_iff]
  constructor
  · intro hx
    rcases hx with ⟨i, rfl⟩
    fin_cases i <;> simp
  · intro hx
    rcases hx with hx | hx
    · exact ⟨0, by simp [hx]⟩
    · exact ⟨1, by simp [hx]⟩

/-- **Worked example: `[ℚ(i, √5) : ℚ] = 4`.** This is the Layer-0 degree statement for the
multiquadratic field generated by the prime-discriminant radicands `-1` and `5`, the
genus-field generator list for `ℚ(√-5)`. -/
theorem finrank_adjoin_I_sqrt_five :
    Module.finrank ℚ
      (adjoin ℚ ({Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)} : Set ℂ) : IntermediateField ℚ ℂ) = 4 := by
  have h := finrank_adjoin_roots_primeDiscriminantRadicands negFivePrimeDiscriminants
    isPrimeDiscriminant_negFivePrimeDiscriminants injective_negFivePrimeDiscriminants
    not_all_even_negFivePrimeDiscriminants
    (fun i : Fin 2 => ![Complex.I, ((Real.sqrt 5 : ℝ) : ℂ)] i) root_neg_four_five_sq
  rw [range_roots_neg_four_five] at h
  exact h.trans (by norm_num [Nat.card_fin])

/-- The prime-discriminant list `[-4, -3, -7]` for the `ℚ(√-21)` genus-field generators. -/
private def negTwentyOnePrimeDiscriminants : Fin 3 → ℤ :=
  ![(-4 : ℤ), -3, -7]

/-- The complex square root data for the prime discriminants `-4`, `-3`, and `-7`: the
associated radicands are `-1`, `-3`, and `-7`, with roots `i`, `i√3`, and `i√7`. -/
private theorem root_neg_four_neg_three_neg_seven_sq (i : Fin 3) :
    (fun i : Fin 3 => ![Complex.I, sqrtNegThree, sqrtNegSeven] i) i ^ 2 =
      algebraMap ℚ ℂ
        (((primeDiscriminantRadicand (negTwentyOnePrimeDiscriminants i) : ℤ) : ℚ)) := by
  fin_cases i
  · simp [negTwentyOnePrimeDiscriminants, Complex.I_sq]
  · have hrad : primeDiscriminantRadicand (-3) = -3 := by
      have h := primeDiscriminantRadicand_oddPrimeDiscriminant (p := 3) (by decide)
      simpa [oddPrimeDiscriminant_of_mod_four_eq_three (by norm_num : 3 % 4 = 3)] using h
    simp [negTwentyOnePrimeDiscriminants, hrad]
  · have hrad : primeDiscriminantRadicand (-7) = -7 := by
      have h := primeDiscriminantRadicand_oddPrimeDiscriminant (p := 7) (by decide)
      simpa [oddPrimeDiscriminant_of_mod_four_eq_three (by norm_num : 7 % 4 = 3)] using h
    simp [negTwentyOnePrimeDiscriminants, hrad]

private theorem isPrimeDiscriminant_negTwentyOnePrimeDiscriminants :
    ∀ i : Fin 3, IsPrimeDiscriminant (negTwentyOnePrimeDiscriminants i) := by
  intro i
  fin_cases i
  · simp [negTwentyOnePrimeDiscriminants]
  · have h3 : IsPrimeDiscriminant (oddPrimeDiscriminant 3) :=
      isPrimeDiscriminant_oddPrimeDiscriminant (p := 3) (by decide) (by decide)
    simpa [negTwentyOnePrimeDiscriminants,
      oddPrimeDiscriminant_of_mod_four_eq_three (by norm_num : 3 % 4 = 3)] using h3
  · have h7 : IsPrimeDiscriminant (oddPrimeDiscriminant 7) :=
      isPrimeDiscriminant_oddPrimeDiscriminant (p := 7) (by decide) (by decide)
    simpa [negTwentyOnePrimeDiscriminants,
      oddPrimeDiscriminant_of_mod_four_eq_three (by norm_num : 7 % 4 = 3)] using h7

private theorem injective_negTwentyOnePrimeDiscriminants :
    Function.Injective negTwentyOnePrimeDiscriminants := by
  decide

private theorem not_all_even_negTwentyOnePrimeDiscriminants :
    ¬ ((∃ i : Fin 3, negTwentyOnePrimeDiscriminants i = -4) ∧
      (∃ i : Fin 3, negTwentyOnePrimeDiscriminants i = 8) ∧
        (∃ i : Fin 3, negTwentyOnePrimeDiscriminants i = -8)) := by
  decide

private theorem range_roots_neg_four_neg_three_neg_seven :
    (Set.range fun i : Fin 3 => ![Complex.I, sqrtNegThree, sqrtNegSeven] i)
      = {Complex.I, sqrtNegThree, sqrtNegSeven} := by
  ext x
  simp only [Set.mem_range, Set.mem_insert_iff, Set.mem_singleton_iff]
  constructor
  · intro hx
    rcases hx with ⟨i, rfl⟩
    fin_cases i <;> simp
  · intro hx
    rcases hx with hx | hx | hx
    · exact ⟨0, by simp [hx]⟩
    · exact ⟨1, by simp [hx]⟩
    · exact ⟨2, by simp [hx]⟩

/-- **Worked example: `[ℚ(i, √-3, √-7) : ℚ] = 8`.** This is the Layer-0 degree statement for
the multiquadratic field generated by the prime-discriminant radicands `-1`, `-3`, and `-7`,
the genus-field generator list for `ℚ(√-21)`. -/
theorem finrank_adjoin_I_sqrt_neg_three_sqrt_neg_seven :
    Module.finrank ℚ
      (adjoin ℚ ({Complex.I, sqrtNegThree, sqrtNegSeven} : Set ℂ) : IntermediateField ℚ ℂ)
      = 8 := by
  have h := finrank_adjoin_roots_primeDiscriminantRadicands negTwentyOnePrimeDiscriminants
    isPrimeDiscriminant_negTwentyOnePrimeDiscriminants injective_negTwentyOnePrimeDiscriminants
    not_all_even_negTwentyOnePrimeDiscriminants
    (fun i : Fin 3 => ![Complex.I, sqrtNegThree, sqrtNegSeven] i)
    root_neg_four_neg_three_neg_seven_sq
  rw [range_roots_neg_four_neg_three_neg_seven] at h
  exact h.trans (by norm_num [Nat.card_fin])

end TauCeti.Multiquadratic
