module

public import TauCeti.NumberTheory.Multiquadratic.PrimeRadicands
public import TauCeti.NumberTheory.Multiquadratic.SubfieldLattice

/-!
# Prime-radicand subfield lattices

This file specializes the field-generic multiquadratic subfield/subspace dictionary from
`TauCeti.NumberTheory.Multiquadratic.SubfieldLattice` to fields
`‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)` generated by square roots of a finite family of distinct primes. The prime-specific
square-class independence input comes from `TauCeti.NumberTheory.Multiquadratic.PrimeRadicands`.

## Main results

* `TauCeti.Multiquadratic.intermediateFieldEquivSubmoduleSqrtPrimes`: for a finite family of
  distinct primes `p : őĻ ‚Üí ‚Ąē`, the order-reversing bijection between intermediate fields of
  `‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)` and `ūĚĒĹ‚āā`-subspaces of `őĻ ‚Üí ‚Ą§/2`.
* `TauCeti.Multiquadratic.card_intermediateField_adjoin_sqrt_primes`: the corresponding
  cardinality statement.
-/

public section

open IntermediateField

namespace TauCeti.Multiquadratic

variable {őĻ : Type*}

section PrimeFamily

variable [Finite őĻ] (p : őĻ ‚Üí ‚Ąē) (hp : ‚ąÄ i, (p i).Prime) (hinj : Function.Injective p)

omit [Finite őĻ] in
/-- The square roots `‚ąö(p i)` of a prime family satisfy the radicand equation `‚ąö(p i)¬≤ = p i`. -/
private theorem sqrtPrime_sq (i : őĻ) : Real.sqrt (p i) ^ 2 = algebraMap ‚Ąö ‚ĄĚ (p i : ‚Ąö) :=
  sq_sqrt_natCast (p i)

include hp hinj

/-- **The subfield lattice of `‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)`.** For a finite family of distinct primes
`p : őĻ ‚Üí ‚Ąē`, the intermediate fields of `‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)/‚Ąö` correspond, order-reversingly, to the
`ūĚĒĹ‚āā`-subspaces of `őĻ ‚Üí ‚Ą§/2`. This is the prime-radicand specialization of
`intermediateFieldEquivSubmodule`, a genus-theory input. -/
noncomputable def intermediateFieldEquivSubmoduleSqrtPrimes :
    IntermediateField ‚Ąö (adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ))) ‚ČÉo
      (Submodule (ZMod 2) (őĻ ‚Üí ZMod 2))ŠĶíŠĶą :=
  intermediateFieldEquivSubmodule (sqrtPrime_sq p)
    (not_isSquare_prod_primes_of_injective p hp hinj)

/-- A sign vector belongs to the subspace attached to an intermediate field of
`‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)` exactly when it is the sign pattern of an automorphism fixing that field. -/
theorem mem_intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_iff
    (F : IntermediateField ‚Ąö (adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ))))
    (v : őĻ ‚Üí ZMod 2) :
    v ‚ąą (intermediateFieldEquivSubmoduleSqrtPrimes p hp hinj F).ofDual ‚ÜĒ
      ‚ąÉ ŌÉ ‚ąą F.fixingSubgroup, signPattern (fun i => (Real.sqrt (p i) : ‚ĄĚ)) ŌÉ = v :=
  mem_intermediateFieldEquivSubmodule_apply_ofDual_iff (sqrtPrime_sq p)
    (not_isSquare_prod_primes_of_injective p hp hinj) F v

/-- The intermediate field attached to a subspace in the prime-radicand dictionary is the fixed
field of the automorphisms whose sign patterns lie in that subspace. -/
theorem mem_intermediateFieldEquivSubmoduleSqrtPrimes_symm_apply_iff
    (U : Submodule (ZMod 2) (őĻ ‚Üí ZMod 2))
    (x : adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ))) :
    x ‚ąą (intermediateFieldEquivSubmoduleSqrtPrimes p hp hinj).symm (OrderDual.toDual U) ‚ÜĒ
      ‚ąÄ ŌÉ, signPattern (fun i => (Real.sqrt (p i) : ‚ĄĚ)) ŌÉ ‚ąą U ‚Üí ŌÉ x = x :=
  mem_intermediateFieldEquivSubmodule_symm_apply_iff (sqrtPrime_sq p)
    (not_isSquare_prod_primes_of_injective p hp hinj) U x

/-- **The number of subfields of `‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)`.** For a finite family of distinct primes, the
intermediate fields of `‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)/‚Ąö` are in bijection with the `ūĚĒĹ‚āā`-subspaces of `őĻ ‚Üí ‚Ą§/2`. -/
theorem card_intermediateField_adjoin_sqrt_primes :
    Nat.card (IntermediateField ‚Ąö (adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ))))
      = Nat.card (Submodule (ZMod 2) (őĻ ‚Üí ZMod 2)) :=
  card_intermediateField_adjoin_range (sqrtPrime_sq p)
    (not_isSquare_prod_primes_of_injective p hp hinj)

end PrimeFamily

end TauCeti.Multiquadratic
