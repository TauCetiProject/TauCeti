module

public import TauCeti.NumberTheory.Multiquadratic.PrimeSubfieldLattice
public import TauCeti.NumberTheory.Multiquadratic.SubfieldDegree

/-!
# Degrees in prime-radicand multiquadratic subfield lattices

The file `TauCeti.NumberTheory.Multiquadratic.PrimeSubfieldLattice` specializes the
multiquadratic subfield/subspace dictionary to fields `‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)` generated by square
roots of a finite family of distinct primes. This file records the matching degree readings:
the degree of an intermediate field times the size of its attached `ūĚĒĹ‚āā`-subspace is `2‚ĀŅ`, and
the quadratic subfields are exactly the hyperplanes.

These are the prime-radicand consumer forms of the field-generic results in
`TauCeti.NumberTheory.Multiquadratic.SubfieldDegree`, using
`TauCeti.Multiquadratic.not_isSquare_prod_primes_of_injective` for square-class independence.
They support the Layer 0 multiquadratic roadmap target identifying subfields with
`ūĚĒĹ‚āā`-subspaces, with the degree interpretation needed to organize quadratic subfields.

The point of the specializations is that their statements mention the public prime-radicand
dictionary `intermediateFieldEquivSubmoduleSqrtPrimes`. A consumer working in
`‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)` should not have to expose the private square-root equation or repeat the
prime-family square-class-independence witness just to state a degree fact. The proofs below
therefore remain thin rewrites to the generic API rather than new degree arguments.

## Main results

* `TauCeti.Multiquadratic.finrank_mul_card_intermediateFieldEquivSubmoduleSqrtPrimes`:
  `[F : ‚Ąö] ¬∑ |U| = 2‚ĀŅ` for the subspace `U` attached to `F`.
* `TauCeti.Multiquadratic.finrank_intermediateField_sqrtPrimes_eq_two_pow`:
  `[F : ‚Ąö] = 2 ^ (n - dim U)`.
* `TauCeti.Multiquadratic.finrank_intermediateField_sqrtPrimes_eq_two_iff`:
  the quadratic intermediate fields are exactly those whose attached subspace is a hyperplane.
-/

public section

open IntermediateField Module

namespace TauCeti.Multiquadratic

variable {őĻ : Type*}

section PrimeFamily

variable [Finite őĻ] (p : őĻ ‚Üí ‚Ąē) (hp : ‚ąÄ i, (p i).Prime) (hinj : Function.Injective p)

omit [Finite őĻ] in
/-- The square roots `‚ąö(p i)` of a prime family satisfy the radicand equation `‚ąö(p i)¬≤ = p i`.
This is the `hroot` input used by the field-generic subfield-degree results. -/
private theorem sqrtPrime_sq (i : őĻ) : Real.sqrt (p i) ^ 2 = algebraMap ‚Ąö ‚ĄĚ (p i : ‚Ąö) :=
  sq_sqrt_natCast (p i)

include hp hinj

/-- The subspace attached by the public prime-radicand dictionary is extensionally the same as
the generic dictionary fed the prime-family square-class independence proof. -/
private theorem intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_eq
    (F : IntermediateField ‚Ąö (adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ)))) :
    (intermediateFieldEquivSubmoduleSqrtPrimes p hp hinj F).ofDual =
      (intermediateFieldEquivSubmodule (sqrtPrime_sq p)
        (not_isSquare_prod_primes_of_injective p hp hinj) F).ofDual := by
  ext v
  rw [mem_intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_iff,
    mem_intermediateFieldEquivSubmodule_apply_ofDual_iff]
  rfl

/-- **Degree/subspace-size relation for prime-radicand subfields.** For an intermediate field
`F` of `‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)`, `[F : ‚Ąö]` times the size of its attached subspace under
`intermediateFieldEquivSubmoduleSqrtPrimes` is `2 ^ |őĻ|`. -/
theorem finrank_mul_card_intermediateFieldEquivSubmoduleSqrtPrimes
    (F : IntermediateField ‚Ąö (adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ)))) :
    Module.finrank ‚Ąö F
        * Nat.card (intermediateFieldEquivSubmoduleSqrtPrimes p hp hinj F).ofDual
      = 2 ^ Nat.card őĻ :=
by
  rw [intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_eq p hp hinj F]
  exact finrank_mul_card_intermediateFieldEquivSubmodule (sqrtPrime_sq p)
    (not_isSquare_prod_primes_of_injective p hp hinj) F

/-- **Degree/subspace-dimension relation for prime-radicand subfields.** For an intermediate
field `F` of `‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)`, `[F : ‚Ąö] ¬∑ 2 ^ dim U = 2 ^ |őĻ|`, where `U` is the attached
subspace under `intermediateFieldEquivSubmoduleSqrtPrimes`. -/
theorem finrank_mul_two_pow_finrank_intermediateFieldEquivSubmoduleSqrtPrimes
    (F : IntermediateField ‚Ąö (adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ)))) :
    Module.finrank ‚Ąö F
        * 2 ^ Module.finrank (ZMod 2) (intermediateFieldEquivSubmoduleSqrtPrimes p hp hinj F).ofDual
      = 2 ^ Nat.card őĻ :=
by
  rw [intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_eq p hp hinj F]
  exact finrank_mul_two_pow_finrank_intermediateFieldEquivSubmodule (sqrtPrime_sq p)
    (not_isSquare_prod_primes_of_injective p hp hinj) F

/-- **Degree of a prime-radicand intermediate field.** For an intermediate field `F` of
`‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)`, its degree is `2` to the codimension of the attached subspace. -/
theorem finrank_intermediateField_sqrtPrimes_eq_two_pow
    (F : IntermediateField ‚Ąö (adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ)))) :
    Module.finrank ‚Ąö F =
      2 ^ (Nat.card őĻ
        - Module.finrank (ZMod 2) (intermediateFieldEquivSubmoduleSqrtPrimes p hp hinj F).ofDual) :=
by
  rw [intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_eq p hp hinj F]
  exact finrank_intermediateField_eq_two_pow (sqrtPrime_sq p)
    (not_isSquare_prod_primes_of_injective p hp hinj) F

/-- **Quadratic subfields in the prime-radicand dictionary.** An intermediate field of
`‚Ąö(‚ąöp‚āĀ, ‚Ä¶, ‚ąöp‚āô)` has degree `2` over `‚Ąö` exactly when its attached subspace is a hyperplane. -/
theorem finrank_intermediateField_sqrtPrimes_eq_two_iff
    (F : IntermediateField ‚Ąö (adjoin ‚Ąö (Set.range fun i => (Real.sqrt (p i) : ‚ĄĚ)))) :
    Module.finrank ‚Ąö F = 2 ‚ÜĒ
      Module.finrank (ZMod 2) (intermediateFieldEquivSubmoduleSqrtPrimes p hp hinj F).ofDual + 1
        = Nat.card őĻ :=
by
  rw [intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_eq p hp hinj F]
  exact finrank_intermediateField_eq_two_iff (sqrtPrime_sq p)
    (not_isSquare_prod_primes_of_injective p hp hinj) F

end PrimeFamily

end TauCeti.Multiquadratic
