module

public import TauCeti.NumberTheory.Multiquadratic.PrimeSubfieldLattice
public import TauCeti.NumberTheory.Multiquadratic.SubfieldDegree

/-!
# Prime-radicand bridge for multiquadratic subfield degrees

The file `TauCeti.NumberTheory.Multiquadratic.PrimeSubfieldLattice` specializes the
multiquadratic subfield/subspace dictionary to fields `ℚ(√p₁, …, √pₙ)` generated by square
roots of a finite family of distinct primes. The generic degree API in
`TauCeti.NumberTheory.Multiquadratic.SubfieldDegree` applies to that dictionary after supplying
the square-root equation and the prime-family square-class-independence proof.

This file records only the bridge: the subspace attached by the public prime-radicand dictionary
is extensionally the same as the one attached by the generic dictionary with those inputs. Degree
statements should be read from `SubfieldDegree` using this equality, rather than through a
parallel prime-specific degree API.

## Main results

* `TauCeti.Multiquadratic.intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_eq`:
  the `ofDual` subspace from the public prime-radicand dictionary agrees with the generic
  dictionary specialized to `sq_sqrt_natCast` and
  `not_isSquare_prod_primes_of_injective`.
-/

public section

open IntermediateField Module

namespace TauCeti.Multiquadratic

variable {ι : Type*}

section PrimeFamily

variable [Finite ι] (p : ι → ℕ) (hp : ∀ i, (p i).Prime) (hinj : Function.Injective p)

include hp hinj

/-- The subspace attached by the public prime-radicand dictionary is extensionally the same as
the generic dictionary fed the prime-family square-class independence proof. This lets consumers
use the degree theorems from `SubfieldDegree` with
`intermediateFieldEquivSubmoduleSqrtPrimes` without a parallel prime-specific degree API. -/
theorem intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_eq
    (F : IntermediateField ℚ (adjoin ℚ (Set.range fun i => (Real.sqrt (p i) : ℝ)))) :
    (intermediateFieldEquivSubmoduleSqrtPrimes p hp hinj F).ofDual =
      (intermediateFieldEquivSubmodule (fun i => sq_sqrt_natCast (p i))
        (not_isSquare_prod_primes_of_injective p hp hinj) F).ofDual := by
  ext v
  rw [mem_intermediateFieldEquivSubmoduleSqrtPrimes_apply_ofDual_iff,
    mem_intermediateFieldEquivSubmodule_apply_ofDual_iff]
  rfl

end PrimeFamily

end TauCeti.Multiquadratic
