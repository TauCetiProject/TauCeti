public import Mathlib.Algebra.DualNumber
public import Mathlib.RingTheory.Ideal.Quotient.Operations
public import TauCeti.Algebra.AlgebraicGroup.AdditiveGroup.Frobenius
public import TauCeti.Algebra.HopfAlgebra.HopfIdeal.Basic

/-!
# The Frobenius kernel group scheme `Œ±‚Çö`

Over a base ring `R` of prime characteristic `p`, the additive group `ùîæ‚Çê = Spec R[x]`
(here `x = Œπ R R 1` in `SymmetricAlgebra R R`) has a closed subgroup scheme `Œ±‚Çö`, the kernel of
the Frobenius endomorphism `x ‚Ü¶ x·µñ`. Its coordinate ring is the quotient Hopf algebra
`R[x] / (x·µñ)`, and for every commutative `R`-algebra `A` its `A`-points are the `p`-nilpotent
elements of `A`: the elements `a ‚àà A` with `a·µñ = 0`. (This is the Frobenius kernel, not the
kernel of multiplication by `p`; in characteristic `p` the latter is all of `ùîæ‚Çê`.)

This file builds `Œ±‚Çö` as the quotient of the additive-group Hopf algebra by the Hopf ideal
generated by `x·µñ`, and identifies its functor of points with these `p`-nilpotent elements.

The Hopf-ideal check is the freshman's dream in characteristic `p`: because `x` is primitive,
`Œî x = x ‚äó 1 + 1 ‚äó x`, and in characteristic `p`
`Œî(x·µñ) = (x ‚äó 1 + 1 ‚äó x)·µñ = x·µñ ‚äó 1 + 1 ‚äó x·µñ ‚àà (x·µñ) ‚äó R[x] + R[x] ‚äó (x·µñ)`
(`TauCeti.AdditiveGroup.comul_Œπ_pow`, the shared primitivity of `x·µñ`). The counit vanishes on
`x·µñ` since `Œµ x = 0`, and
the antipode preserves `(x·µñ)` since `S(x·µñ) = (-x)·µñ`. Mathlib's quotient Hopf-algebra instance
then equips `R[x] / (x·µñ)` with its Hopf structure through the bridge instances of
`TauCeti.Algebra.HopfAlgebra.HopfIdeal.Basic`.

The functor of points is recovered by pre-composing points of `Œ±‚Çö` with the quotient map
`R[x] ‚Üí R[x] / (x·µñ)` (a bialgebra morphism, hence a convolution homomorphism through
`TauCeti.AlgHom.mapDomain`) and reading the resulting `ùîæ‚Çê`-point off with
`TauCeti.AdditiveGroup.gaPointsMulEquiv`. The image consists of exactly the `p`-nilpotent
elements, and the pre-composition map is injective because the quotient map is surjective, so
`Œ±‚Çö(A)` is the additive group of `p`-nilpotent elements of `A` (those `a` with `a·µñ = 0`). This
exhibits `Œ±‚Çö` as a non-reduced affine group scheme, the additive companion of the `Œº_p` example of
`TauCeti.Algebra.AlgebraicGroup.GroupAlgebra.NotReduced`.

This is the worked example `Œ±‚Çö` from the Tau Ceti reductive-groups roadmap
(`ReductiveGroups/README.md` in TauCetiRoadmap): the standing hypotheses note that an affine
group scheme of finite type "admits `Œº_p`, `Œ±‚Çö`, and other non-smooth / non-reduced groups",
and Layer 3 develops "Hopf ideals ‚Üî closed subgroup schemes".

## Main declarations

* `TauCeti.AlphaP.hopfIdeal`: the Hopf ideal `(x·µñ)` of the additive-group Hopf algebra.
* `TauCeti.AlphaP.CoordinateRing`: the coordinate Hopf algebra `R[x] / (x·µñ)` of `Œ±‚Çö`.
* `TauCeti.AlphaP.pointsHom`: the injective homomorphism from the convolution group of points of
  `Œ±‚Çö` to the additive group `Multiplicative A`, landing in the `p`-nilpotent elements.
* `TauCeti.AlphaP.mem_range_pointsHom_iff`: a point value `a` comes from `Œ±‚Çö` iff `a·µñ = 0`, so
  the functor of points of `Œ±‚Çö` is the `p`-nilpotent elements of the additive group.
* `TauCeti.AlphaP.pNilpotent`: the `p`-nilpotent elements as a subgroup of the additive group.
* `TauCeti.AlphaP.pointsMulEquiv`: the group isomorphism identifying the points of `Œ±‚Çö` with the
  `p`-nilpotent subgroup.

## References

The Hopf structure on the additive group is Tau Ceti's
`TauCeti.Algebra.HopfAlgebra.SymmetricAlgebra` and
`TauCeti.Algebra.AlgebraicGroup.AdditiveGroup.Basic`; the Hopf-ideal quotient machinery and its
bridge to Mathlib's quotient Hopf algebra are `TauCeti.Algebra.HopfAlgebra.HopfIdeal.Basic`. The
primitivity of `x·µñ` reuses `TauCeti.AdditiveGroup.comul_Œπ_pow` of
`TauCeti.Algebra.AlgebraicGroup.AdditiveGroup.Frobenius`; the tensor-product bialgebra structure
is from Mathlib.
-/

public section

open Coalgebra HopfAlgebra SymmetricAlgebra WithConv
open scoped TensorProduct

namespace TauCeti

namespace AlphaP

universe u v

variable {R : Type u} [CommRing R] (p : ‚Ñï) [Fact p.Prime] [CharP R p]

/-- The comultiplication of the generating relation `x·µñ` lands in `(x·µñ) ‚äó R[x] + R[x] ‚äó (x·µñ)`:
by the freshman's dream in characteristic `p`, `Œî(x·µñ) = x·µñ ‚äó 1 + 1 ‚äó x·µñ`
(`TauCeti.AdditiveGroup.comul_Œπ_pow`). -/
private theorem comul_gen_mem :
    Coalgebra.comul (R := R) (Œπ R R 1 ^ p) ‚àà
      HopfIdeal.leftTensorIdeal (R := R) (H := SymmetricAlgebra R R)
          (Ideal.span {(Œπ R R 1 : SymmetricAlgebra R R) ^ p}) ‚äî
        HopfIdeal.rightTensorIdeal (R := R) (H := SymmetricAlgebra R R)
          (Ideal.span {(Œπ R R 1 : SymmetricAlgebra R R) ^ p}) := by
  rw [AdditiveGroup.comul_Œπ_pow R p]
  exact Ideal.add_mem _
    (Ideal.mem_sup_left
      (HopfIdeal.tmul_mem_leftTensorIdeal (R := R) (H := SymmetricAlgebra R R)
        (Ideal.mem_span_singleton_self _) 1))
    (Ideal.mem_sup_right
      (HopfIdeal.tmul_mem_rightTensorIdeal (R := R) (H := SymmetricAlgebra R R) 1
        (Ideal.mem_span_singleton_self _)))

omit [CharP R p] in
/-- The counit vanishes on `x·µñ`, since `Œµ x = 0`. -/
private theorem counit_gen :
    Coalgebra.counit (R := R) ((Œπ R R 1 : SymmetricAlgebra R R) ^ p) = 0 := by
  rw [Bialgebra.counit_pow, SymmetricAlgebra.counit_Œπ,
    zero_pow (Fact.out (p := p.Prime)).ne_zero]

omit [Fact p.Prime] [CharP R p] in
/-- The antipode preserves the ideal `(x·µñ)`, since `S(x·µñ) = (-x)·µñ = (-1)·µñ x·µñ`. -/
private theorem antipode_gen_mem :
    HopfAlgebra.antipode R ((Œπ R R 1 : SymmetricAlgebra R R) ^ p) ‚àà
      Ideal.span {(Œπ R R 1 : SymmetricAlgebra R R) ^ p} := by
  have hpow : HopfAlgebra.antipode R ((Œπ R R 1 : SymmetricAlgebra R R) ^ p) =
      (HopfAlgebra.antipode R (Œπ R R 1 : SymmetricAlgebra R R)) ^ p :=
    map_pow (HopfAlgebra.antipodeAlgHom R _) _ _
  rw [hpow, TauCeti.SymmetricAlgebra.antipode_Œπ, neg_pow]
  exact Ideal.mul_mem_left _ _ (Ideal.mem_span_singleton_self _)

/-- **The Hopf ideal `(x·µñ)` of the additive group.** For `R` of prime characteristic `p`, the
principal ideal generated by `x·µñ` in the coordinate Hopf algebra `R[x]` of `ùîæ‚Çê` is a Hopf
ideal: its comultiplication lands in `(x·µñ) ‚äó R[x] + R[x] ‚äó (x·µñ)`, its counit vanishes, and it is
antipode-stable. Its quotient is the coordinate ring of the Frobenius kernel group scheme
`Œ±‚Çö`. -/
@[expose] noncomputable def hopfIdeal : HopfIdeal R (SymmetricAlgebra R R) :=
  HopfIdeal.ofIdeal (Ideal.span {(Œπ R R 1 : SymmetricAlgebra R R) ^ p})
    (fun y hy => by
      obtain ‚ü®c, rfl‚ü© := Ideal.mem_span_singleton'.mp hy
      rw [Bialgebra.comul_mul]
      exact Ideal.mul_mem_left _ _ (comul_gen_mem p))
    (fun y hy => by
      obtain ‚ü®c, rfl‚ü© := Ideal.mem_span_singleton'.mp hy
      rw [Bialgebra.counit_mul, counit_gen, mul_zero])
    (fun y hy => by
      obtain ‚ü®c, rfl‚ü© := Ideal.mem_span_singleton'.mp hy
      rw [HopfAlgebra.antipode_mul_distrib]
      exact Ideal.mul_mem_left _ _ (antipode_gen_mem p))

@[simp]
theorem hopfIdeal_toIdeal :
    (hopfIdeal (R := R) p).toIdeal = Ideal.span {(Œπ R R 1 : SymmetricAlgebra R R) ^ p} :=
  rfl

/-- **The coordinate Hopf algebra of `Œ±‚Çö`**, the quotient `R[x] / (x·µñ)`. It carries a Hopf
algebra structure through the bridge instances of `TauCeti.Algebra.HopfAlgebra.HopfIdeal.Basic`. -/
noncomputable abbrev CoordinateRing : Type u :=
  SymmetricAlgebra R R ‚ß∏ (hopfIdeal (R := R) p).toIdeal

/-- The class of `x` in the coordinate ring of `Œ±‚Çö` is `p`-nilpotent: its `p`-th power is `0`. -/
@[simp]
theorem mk_Œπ_pow_eq_zero :
    (Ideal.Quotient.mk (hopfIdeal (R := R) p).toIdeal
        (Œπ R R 1 : SymmetricAlgebra R R)) ^ p = 0 := by
  rw [‚Üê map_pow, Ideal.Quotient.eq_zero_iff_mem, hopfIdeal_toIdeal]
  exact Ideal.mem_span_singleton_self _

/-- The class of `x` in the coordinate ring of `Œ±‚Çö` is nonzero over a nontrivial base: the
dual-number test algebra `R[Œµ]` receives `x ‚Ü¶ Œµ`, sending the relation `x·µñ` to `Œµ·µñ = 0` (as
`p ‚â• 2`) but not `x` itself. So `x·µñ` does not divide `x` in `R[x]`. -/
theorem mk_Œπ_ne_zero [Nontrivial R] :
    Ideal.Quotient.mk (hopfIdeal (R := R) p).toIdeal (Œπ R R 1 : SymmetricAlgebra R R) ‚âÝ 0 := by
  rw [Ne, Ideal.Quotient.eq_zero_iff_mem, hopfIdeal_toIdeal, Ideal.mem_span_singleton']
  rintro ‚ü®c, hc‚ü©
  set ev : SymmetricAlgebra R R ‚Üí‚Çê[R] DualNumber R :=
    SymmetricAlgebra.lift (LinearMap.toSpanSingleton R (DualNumber R) DualNumber.eps) with hev
  have hev1 : ev (Œπ R R 1) = DualNumber.eps := by
    rw [hev, SymmetricAlgebra.lift_Œπ_apply, LinearMap.toSpanSingleton_apply, one_smul]
  have hepsp : (DualNumber.eps : DualNumber R) ^ p = 0 :=
    pow_eq_zero_of_le (Fact.out (p := p.Prime)).two_le DualNumber.eps_pow_two
  have heps0 : (DualNumber.eps : DualNumber R) = 0 := by
    rw [‚Üê hev1, ‚Üê hc, map_mul, map_pow, hev1, hepsp, mul_zero]
  have hsnd := congrArg TrivSqZeroExt.snd heps0
  rw [DualNumber.snd_eps, TrivSqZeroExt.snd_zero] at hsnd
  exact one_ne_zero hsnd

/-- **The coordinate ring of `Œ±‚Çö` is not reduced.** Over a nontrivial base of characteristic `p`,
the class of `x` is a nonzero nilpotent (`xÃÑ·µñ = 0`), so `R[x] / (x·µñ)` is non-reduced. This is the
additive companion of the non-reduced `Œº_p` example. -/
theorem coordinateRing_not_isReduced [Nontrivial R] :
    ¬¨ IsReduced (CoordinateRing (R := R) p) := by
  intro hred
  haveI := hred
  exact mk_Œπ_ne_zero p
    (IsNilpotent.eq_zero (x := Ideal.Quotient.mk _ (Œπ R R 1)) ‚ü®p, mk_Œπ_pow_eq_zero p‚ü©)

section Points

variable {A : Type v} [CommRing A] [Algebra R A]

/-- **The functor of points of `Œ±‚Çö`, as a subgroup of the additive group.** Pre-composition of a
point of `Œ±‚Çö` with the quotient map `R[x] ‚Üí R[x] / (x·µñ)` gives a point of `ùîæ‚Çê`, read off as an
element of `Multiplicative A` by `TauCeti.AdditiveGroup.gaPointsMulEquiv`. -/
@[expose] noncomputable def pointsHom :
    WithConv (CoordinateRing (R := R) p ‚Üí‚Çê[R] A) ‚Üí* Multiplicative A :=
  (AdditiveGroup.gaPointsMulEquiv (R := R) (A := A)).toMonoidHom.comp
    (AlgHom.mapDomain (Bialgebra.Quotient.mkBialgHom (hopfIdeal (R := R) p).toIdeal))

/-- A point of `Œ±‚Çö` is sent to the value at `x` of its underlying `R[x]`-point: the element
`F(xÃÑ)` of `A`, where `xÃÑ` is the class of `x` in the coordinate ring. -/
@[simp]
theorem toAdd_pointsHom (F : WithConv (CoordinateRing (R := R) p ‚Üí‚Çê[R] A)) :
    Multiplicative.toAdd (pointsHom p F) =
      F.ofConv (Ideal.Quotient.mk (hopfIdeal (R := R) p).toIdeal
        (Œπ R R 1 : SymmetricAlgebra R R)) := by
  simp only [pointsHom, MonoidHom.comp_apply, MulEquiv.coe_toMonoidHom,
    AdditiveGroup.toAdd_gaPointsMulEquiv, AlgHom.mapDomain_apply,
    AlgHom.comp_apply, BialgHom.coe_toAlgHom, Bialgebra.Quotient.mkBialgHom_apply]

/-- The points homomorphism of `Œ±‚Çö` is injective, because the quotient map `R[x] ‚Üí R[x] / (x·µñ)`
is surjective, so pre-composition with it is injective on algebra homomorphisms. -/
theorem pointsHom_injective : Function.Injective (pointsHom (R := R) p (A := A)) := by
  intro F F' h
  have h2 := (AdditiveGroup.gaPointsMulEquiv (R := R) (A := A)).injective h
  rw [AlgHom.mapDomain_apply, AlgHom.mapDomain_apply] at h2
  have h3 := WithConv.toConv_injective h2
  apply WithConv.ofConv_injective
  apply AlgHom.ext
  intro z
  obtain ‚ü®w, rfl‚ü© := Ideal.Quotient.mk_surjective z
  have hw := DFunLike.congr_fun h3 w
  simp only [AlgHom.comp_apply, BialgHom.coe_toAlgHom,
    Bialgebra.Quotient.mkBialgHom_apply] at hw
  exact hw

/-- **The functor of points of `Œ±‚Çö` is the `p`-nilpotent elements of the additive group.** An
element `a` of `A` is the value of a point of `Œ±‚Çö` iff `a·µñ = 0`. -/
theorem mem_range_pointsHom_iff (a : Multiplicative A) :
    a ‚àà (pointsHom (R := R) p (A := A)).range ‚Üî (Multiplicative.toAdd a) ^ p = 0 := by
  constructor
  ¬∑ rintro ‚ü®F, rfl‚ü©
    rw [toAdd_pointsHom, ‚Üê map_pow, ‚Üê map_pow, Ideal.Quotient.eq_zero_iff_mem.mpr
      (by rw [hopfIdeal_toIdeal]; exact Ideal.mem_span_singleton_self _), map_zero]
  ¬∑ intro h
    set f : SymmetricAlgebra R R ‚Üí‚Çê[R] A :=
      ((AdditiveGroup.gaPointsMulEquiv (R := R) (A := A)).symm a).ofConv with hf
    have hfx : f (Œπ R R 1) = Multiplicative.toAdd a := by
      rw [hf, AdditiveGroup.gaPointsMulEquiv_symm_apply_Œπ]
    have hfker : ‚àÄ z ‚àà (hopfIdeal (R := R) p).toIdeal, f z = 0 := by
      rw [hopfIdeal_toIdeal]
      intro z hz
      obtain ‚ü®c, rfl‚ü© := Ideal.mem_span_singleton'.mp hz
      rw [map_mul, map_pow, hfx, h, mul_zero]
    have hlift : Ideal.Quotient.lift‚Çê (hopfIdeal (R := R) p).toIdeal f hfker
        (Ideal.Quotient.mk (hopfIdeal (R := R) p).toIdeal (Œπ R R 1)) = f (Œπ R R 1) := by
      simp only [Ideal.Quotient.lift‚Çê_apply, Ideal.Quotient.lift_mk, AlgHom.coe_toRingHom]
    refine ‚ü®toConv (Ideal.Quotient.lift‚Çê (hopfIdeal (R := R) p).toIdeal f hfker), ?_‚ü©
    apply Multiplicative.toAdd.injective
    rw [toAdd_pointsHom, ofConv_toConv, hlift, hfx]

/-- **The `p`-nilpotent subgroup of the additive group.** For a commutative `R`-algebra `A`, the
elements `a : A` with `a·µñ = 0` form a subgroup of the additive group `Multiplicative A`: they are
exactly the image of the points homomorphism of `Œ±‚Çö`, hence closed under the group operations. -/
@[expose] noncomputable def pNilpotent : Subgroup (Multiplicative A) :=
  (pointsHom (R := R) p (A := A)).range

/-- Membership in the `p`-nilpotent subgroup is the relation `a·µñ = 0`. -/
@[simp]
theorem mem_pNilpotent_iff (a : Multiplicative A) :
    a ‚àà pNilpotent (R := R) p ‚Üî Multiplicative.toAdd a ^ p = 0 :=
  mem_range_pointsHom_iff p a

/-- **The functor of points of `Œ±‚Çö` as the `p`-nilpotent subgroup.** The points homomorphism
corestricts to a group isomorphism from the convolution group of points of `Œ±‚Çö` onto the
`p`-nilpotent subgroup of the additive group, so `Œ±‚Çö(A)` *is* the group of `p`-nilpotent elements
of `A`. -/
@[expose] noncomputable def pointsMulEquiv :
    WithConv (CoordinateRing (R := R) p ‚Üí‚Çê[R] A) ‚âÉ* pNilpotent (R := R) p (A := A) :=
  MonoidHom.ofInjective (pointsHom_injective (R := R) p (A := A))

/-- The points isomorphism of `Œ±‚Çö` agrees with the points homomorphism on underlying elements. -/
@[simp]
theorem coe_pointsMulEquiv (F : WithConv (CoordinateRing (R := R) p ‚Üí‚Çê[R] A)) :
    (pointsMulEquiv (R := R) p F : Multiplicative A) = pointsHom p F :=
  rfl

/-- The inverse of the points isomorphism of `Œ±‚Çö` is a section of the points homomorphism. -/
@[simp]
theorem pointsHom_pointsMulEquiv_symm (a : pNilpotent (R := R) p (A := A)) :
    pointsHom p ((pointsMulEquiv (R := R) p).symm a) = (a : Multiplicative A) := by
  rw [‚Üê coe_pointsMulEquiv, MulEquiv.apply_symm_apply]

end Points

end AlphaP

end TauCeti
