import Mathlib.GroupTheory.Schreier
import Mathlib.Tactic

/-!
# Index bounds for squaring maps on groups

This file contains an elementary index bound for the range of the squaring map on a group.

## Provenance

Migrated from
[kim-em/erdos-unit-distance](https://github.com/kim-em/erdos-unit-distance)
`ErdosUnitDistance/ClassNumber.lean`, the formalization of L. Alpöge's disproof of the
uniform-constant Erdős unit-distance conjecture.
-/

namespace TauCeti

private theorem index_range_powMonoidHom_le_of_closure_eq_top {G : Type*} [CommGroup G]
    {S : Finset G} {n : ℕ} (hn : 0 < n) (hS : Subgroup.closure (S : Set G) = ⊤) :
    (powMonoidHom n : G →* G).range.index ≤ n ^ S.card := by
  classical
  let H := (powMonoidHom n : G →* G).range
  haveI : Group.FG G := Group.fg_iff.mpr ⟨S, hS, S.finite_toSet⟩
  have hpow : ∀ q : G ⧸ H, q ^ n = 1 := by
    intro q
    obtain ⟨g, rfl⟩ := QuotientGroup.mk'_surjective H q
    rw [← map_pow]
    exact (QuotientGroup.eq_one_iff (N := H) (g ^ n)).mpr ⟨g, rfl⟩
  have hcard : Nat.card (G ⧸ H) ≤ n ^ Group.rank (G ⧸ H) :=
    Nat.le_of_dvd (Nat.pow_pos hn) (card_dvd_exponent_pow_rank' (G := G ⧸ H) hpow)
  have hrank : Group.rank (G ⧸ H) ≤ S.card :=
    (Group.rank_le_of_surjective (QuotientGroup.mk' H) (QuotientGroup.mk'_surjective H)).trans
      (Group.rank_le hS)
  exact hcard.trans (Nat.pow_le_pow_right hn hrank)

/-- In a commutative group generated by a finite set `S`, the range of the squaring map has
index at most `2 ^ S.card`. -/
theorem index_range_powMonoidHom_two_le_of_closure_eq_top {G : Type*} [CommGroup G]
    {S : Finset G} (hS : Subgroup.closure (S : Set G) = ⊤) :
    (powMonoidHom 2 : G →* G).range.index ≤ 2 ^ S.card :=
  index_range_powMonoidHom_le_of_closure_eq_top (by norm_num) hS

end TauCeti
