import Mathlib.FieldTheory.IntermediateField.Adjoin.Basic
import Mathlib.Data.Set.Card

/-!
# Counting simple intermediate fields generated by a finite set

If every field in a set `S` of intermediate fields of `L / K` is `K⟮x⟯` for some `x` drawn from a
fixed finite set `T`, then `S` is finite and has at most `T.ncard` elements: the assignment
`x ↦ K⟮x⟯` maps `T` onto a superset of `S`, so distinct generators can only collapse fields
together.

This is the field-theoretic core of the effective Hermite--Minkowski count. The finiteness half is
the arbitrary-`K` generalization of Mathlib's
`NumberField.hermiteTheorem.finite_of_finite_generating_set`, which proves it over `ℚ` inside the
proof of `NumberField.finite_of_discr_bdd`; here we also add the matching explicit cardinality
bound, both stated for an arbitrary family `S` rather than only the full image of `T`.

## Main results

* `TauCeti.IntermediateField.finite_of_forall_exists_mem_eq_adjoin_simple`
* `TauCeti.IntermediateField.ncard_le_of_forall_exists_mem_eq_adjoin_simple`
-/

open scoped IntermediateField

namespace TauCeti.IntermediateField

variable {K L : Type*} [Field K] [Field L] [Algebra K L]

/-- A set `S` of intermediate fields, each of the form `K⟮x⟯` for some `x` in a fixed set `T`, is
contained in the image of `T` under `x ↦ K⟮x⟯`. -/
theorem subset_image_adjoin_simple {S : Set (IntermediateField K L)} {T : Set L}
    (h : ∀ E ∈ S, ∃ x ∈ T, E = K⟮x⟯) :
    S ⊆ (fun x => (K⟮x⟯ : IntermediateField K L)) '' T := fun E hE => by
  obtain ⟨x, hx, rfl⟩ := h E hE
  exact ⟨x, hx, rfl⟩

/-- If every field in a set `S` of intermediate fields is `K⟮x⟯` for some `x` in a finite set `T`,
then `S` is finite. This is the arbitrary-`K` form of Mathlib's
`NumberField.hermiteTheorem.finite_of_finite_generating_set`. -/
theorem finite_of_forall_exists_mem_eq_adjoin_simple {S : Set (IntermediateField K L)} {T : Set L}
    (hT : T.Finite) (h : ∀ E ∈ S, ∃ x ∈ T, E = K⟮x⟯) : S.Finite :=
  (hT.image _).subset (subset_image_adjoin_simple h)

/-- If every field in a set `S` of intermediate fields is `K⟮x⟯` for some `x` in a finite set `T`,
then `S` has at most `T.ncard` elements. Different generators can produce the same field, so this is
an image-cardinality bound rather than an equality. -/
theorem ncard_le_of_forall_exists_mem_eq_adjoin_simple {S : Set (IntermediateField K L)}
    {T : Set L} (hT : T.Finite) (h : ∀ E ∈ S, ∃ x ∈ T, E = K⟮x⟯) : S.ncard ≤ T.ncard :=
  (Set.ncard_le_ncard (subset_image_adjoin_simple h) (hT.image _)).trans (Set.ncard_image_le hT)

end TauCeti.IntermediateField
