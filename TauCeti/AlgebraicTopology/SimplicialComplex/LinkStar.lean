import Mathlib.AlgebraicTopology.SimplicialComplex.Basic

/-!
# The closed star, link, and deletion of a simplex

For an abstract simplicial complex `K` and a simplex `¤â`, this file builds the three local
subcomplexes that organise `K` around `¤â`:

* the **closed star** `closedStar K ¤â`, the faces `¤ü` whose union with `¤â` is still a face of `K`
  (equivalently, the smallest subcomplex containing every face of `K` that contains `¤â`);
* the **link** `link K ¤â`, the part of the closed star disjoint from `¤â`;
* the **deletion** `deletion K ¤â` (the *anti-star*), the faces of `K` that do not contain `¤â`.

These are the "basic API (faces, the star and link of a simplex)" that the geometric-topology
roadmap (`TauCetiRoadmap/GeometricTopology/README.md`, layer 11) asks for on top of Mathlib's
`AbstractSimplicialComplex`. The link is the load-bearing one downstream: a combinatorial
`n`-manifold is defined there by the condition that the link of every vertex is a combinatorial
`(n-1)`-sphere or `(n-1)`-ball, so `link` is the primitive that condition is phrased against. The
definitions follow Rourke--Sanderson, *Introduction to Piecewise-Linear Topology*, Chapter 3, and
they work for `PreAbstractSimplicialComplex` (the singleton-free version), since the link of a
simplex need not contain every vertex even when `K` does.

## Main definitions

* `TauCeti.PreAbstractSimplicialComplex.closedStar K ¤â`: the closed star of `¤â` in `K`.
* `TauCeti.PreAbstractSimplicialComplex.link K ¤â`: the link of `¤â` in `K`.
* `TauCeti.PreAbstractSimplicialComplex.deletion K ¤â`: the deletion (anti-star) of `¤â` in `K`.

## Main results

* `TauCeti.PreAbstractSimplicialComplex.closedStar_le` / `link_le` / `deletion_le`: each is a
  subcomplex of `K`, and `link_le_closedStar` places the link inside the closed star.
* `TauCeti.PreAbstractSimplicialComplex.closedStar_sup_deletion`: the closed star and the deletion
  cover `K`, i.e. `closedStar K ¤â Ôèö deletion K ¤â = K`.
* `TauCeti.PreAbstractSimplicialComplex.link_le_deletion_of_nonempty`: for a nonempty `¤â`, the
  link sits inside the deletion.
* `TauCeti.PreAbstractSimplicialComplex.mem_link_singleton`: the link of a vertex `{v}`, in the
  `insert`-form used by the combinatorial-manifold link condition.
* `TauCeti.PreAbstractSimplicialComplex.closedStar_empty` / `link_empty` / `deletion_empty`: the
  values at the empty simplex (`K`, `K`, and `ÔèÑ`), pinning the conventions.
* monotonicity of all three constructions in `K`.
-/

namespace TauCeti

open Finset

namespace PreAbstractSimplicialComplex

variable {╬╣ : Type*} [DecidableEq ╬╣] (K L : PreAbstractSimplicialComplex ╬╣) (¤â : Finset ╬╣)

/-- The **closed star** of a simplex `¤â` in `K`: the faces `¤ü` whose union with `¤â` is a face of
`K`. Equivalently, this is the subcomplex of `K` generated by faces whose union with `¤â` remains
in `K`. -/
def closedStar : PreAbstractSimplicialComplex ╬╣ where
  faces := {¤ü | ¤ü.Nonempty Ôêğ ¤ü Ôê¬ ¤â Ôêê K}
  isRelLowerSet_faces := by
    rintro a Ôş¿hane, haKÔş®
    refine Ôş¿hane, fun {b} hba hbne => Ôş¿hbne, ?_Ôş®Ôş®
    exact (K.isRelLowerSet_faces haK).2 (union_subset_union hba Subset.rfl)
      (hbne.mono subset_union_left)

/-- The **link** of a simplex `¤â` in `K`: the part of the closed star disjoint from `¤â`, i.e. the
faces `¤ü` disjoint from `¤â` with `¤ü Ôê¬ ¤â` a face of `K`. This is the primitive the combinatorial
`n`-manifold condition is phrased against: the link of every vertex should be a combinatorial
sphere or ball. -/
def link : PreAbstractSimplicialComplex ╬╣ where
  faces := {¤ü | ¤ü.Nonempty Ôêğ Disjoint ¤ü ¤â Ôêğ ¤ü Ôê¬ ¤â Ôêê K}
  isRelLowerSet_faces := by
    rintro a Ôş¿hane, hdis, haKÔş®
    refine Ôş¿hane, fun {b} hba hbne => Ôş¿hbne, hdis.mono_left hba, ?_Ôş®Ôş®
    exact (K.isRelLowerSet_faces haK).2 (union_subset_union hba Subset.rfl)
      (hbne.mono subset_union_left)

/-- The **deletion** (or *anti-star*) of a simplex `¤â` in `K`: the faces of `K` that do not contain
`¤â` as a subset. Together with the closed star it covers `K` (`closedStar_sup_deletion`). -/
def deletion : PreAbstractSimplicialComplex ╬╣ where
  faces := {¤ü | ¤ü Ôêê K Ôêğ ┬¼ ¤â Ôèå ¤ü}
  isRelLowerSet_faces := by
    rintro a Ôş¿haK, ha¤âÔş®
    refine Ôş¿(K.isRelLowerSet_faces haK).1, fun {b} hba hbne => Ôş¿?_, ?_Ôş®Ôş®
    ┬À exact (K.isRelLowerSet_faces haK).2 hba hbne
    ┬À exact fun h => ha¤â (h.trans hba)

variable {K L ¤â}

@[simp]
theorem mem_closedStar {¤ü : Finset ╬╣} : ¤ü Ôêê closedStar K ¤â Ôåö ¤ü.Nonempty Ôêğ ¤ü Ôê¬ ¤â Ôêê K := Iff.rfl

@[simp]
theorem mem_link {¤ü : Finset ╬╣} :
    ¤ü Ôêê link K ¤â Ôåö ¤ü.Nonempty Ôêğ Disjoint ¤ü ¤â Ôêğ ¤ü Ôê¬ ¤â Ôêê K := Iff.rfl

omit [DecidableEq ╬╣] in
@[simp]
theorem mem_deletion {¤ü : Finset ╬╣} : ¤ü Ôêê deletion K ¤â Ôåö ¤ü Ôêê K Ôêğ ┬¼ ¤â Ôèå ¤ü := Iff.rfl

/-- The closed star of `¤â` is a subcomplex of `K`. -/
theorem closedStar_le : closedStar K ¤â Ôëñ K := by
  rintro ¤ü Ôş¿hne, h¤üÔş®
  exact (K.isRelLowerSet_faces h¤ü).2 subset_union_left hne

/-- The link of `¤â` is a subcomplex of its closed star. -/
theorem link_le_closedStar : link K ¤â Ôëñ closedStar K ¤â :=
  fun _ Ôş¿hne, _, h¤üÔş® => Ôş¿hne, h¤üÔş®

/-- The link of `¤â` is a subcomplex of `K`. -/
theorem link_le : link K ¤â Ôëñ K :=
  link_le_closedStar.trans closedStar_le

omit [DecidableEq ╬╣] in
/-- The deletion of `¤â` is a subcomplex of `K`. -/
theorem deletion_le : deletion K ¤â Ôëñ K :=
  fun _ h¤ü => h¤ü.1

/-- The closed star and the deletion of `¤â` cover `K`: every face either survives in the deletion
(it avoids `¤â`) or lies in the closed star (it, hence its union with `¤â`, is a face). -/
theorem closedStar_sup_deletion : closedStar K ¤â Ôèö deletion K ¤â = K := by
  refine le_antisymm (sup_le closedStar_le deletion_le) fun ¤ü h¤ü => ?_
  rcases em (¤â Ôèå ¤ü) with h | h
  ┬À exact Or.inl Ôş¿(K.isRelLowerSet_faces h¤ü).1, by rwa [union_eq_left.mpr h]Ôş®
  ┬À exact Or.inr Ôş¿h¤ü, hÔş®

/-- For a nonempty simplex `¤â`, the link lies inside the deletion: a face disjoint from a nonempty
`¤â` cannot contain it. -/
theorem link_le_deletion_of_nonempty (h¤â : ¤â.Nonempty) : link K ¤â Ôëñ deletion K ¤â := by
  rintro ¤ü Ôş¿hne, hdis, h¤üÔş®
  refine Ôş¿(K.isRelLowerSet_faces h¤ü).2 subset_union_left hne, fun hsub => ?_Ôş®
  exact h¤â.ne_empty (disjoint_self_iff_empty ¤â |>.mp (hdis.mono_left hsub))

/-- The link of a single vertex `{v}`, written with `insert`: the faces `¤ü` not already containing
`v` for which `insert v ¤ü` is a face. This is the form the combinatorial-manifold link condition
uses. -/
@[simp]
theorem mem_link_singleton {v : ╬╣} {¤ü : Finset ╬╣} :
    ¤ü Ôêê link K {v} Ôåö ¤ü.Nonempty Ôêğ v Ôêë ¤ü Ôêğ insert v ¤ü Ôêê K := by
  rw [mem_link, disjoint_singleton_right, union_comm, ÔåÉ insert_eq]

/-- The closed star at the empty simplex is the whole complex. -/
@[simp]
theorem closedStar_empty : closedStar K Ôêà = K := by
  refine SetLike.ext fun ¤ü => ?_
  simp only [mem_closedStar, union_empty]
  exact Ôş¿fun h => h.2, fun h => Ôş¿(K.isRelLowerSet_faces h).1, hÔş®Ôş®

/-- The link at the empty simplex is the whole complex. -/
@[simp]
theorem link_empty : link K Ôêà = K := by
  refine SetLike.ext fun ¤ü => ?_
  simp only [mem_link, disjoint_empty_right, union_empty, true_and]
  exact Ôş¿fun h => h.2, fun h => Ôş¿(K.isRelLowerSet_faces h).1, hÔş®Ôş®

omit [DecidableEq ╬╣] in
/-- The deletion at the empty simplex is empty: every face contains `Ôêà`. -/
@[simp]
theorem deletion_empty : deletion K Ôêà = ÔèÑ :=
  eq_bot_iff.mpr fun ¤ü h¤ü => (h¤ü.2 (empty_subset ¤ü)).elim

/-- The closed star is monotone in the complex. -/
theorem closedStar_mono (h : K Ôëñ L) : closedStar K ¤â Ôëñ closedStar L ¤â :=
  fun _ Ôş¿hne, h¤üÔş® => Ôş¿hne, h h¤üÔş®

/-- The link is monotone in the complex. -/
theorem link_mono (h : K Ôëñ L) : link K ¤â Ôëñ link L ¤â :=
  fun _ Ôş¿hne, hdis, h¤üÔş® => Ôş¿hne, hdis, h h¤üÔş®

omit [DecidableEq ╬╣] in
/-- The deletion is monotone in the complex. -/
theorem deletion_mono (h : K Ôëñ L) : deletion K ¤â Ôëñ deletion L ¤â :=
  fun _ Ôş¿h¤ü, h¤âÔş® => Ôş¿h h¤ü, h¤âÔş®

end PreAbstractSimplicialComplex

end TauCeti
