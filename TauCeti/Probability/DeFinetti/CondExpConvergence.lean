module

public import TauCeti.MeasureTheory.Function.ConditionalExpectation
public import TauCeti.Probability.Exchangeability.Contractability
public import TauCeti.Probability.Process.Tail

/-!
# Conditional law of a contractable coordinate given the tail

For a contractable process `X`, the conditional law of any coordinate `X m` given the future is the
same as that of `X 0`. Two results, both consumed by the de Finetti directing-measure construction:

* `Contractable.condExp_indicator_future_eq` — for `k ≤ m`, `μ[𝟙_B ∘ X m | σ(tail)] =ᵐ μ[𝟙_B ∘ X k |
  σ(tail)]` conditioning on the **future tail as one random variable** `ω ↦ (X (m+1+·) ω)`. This is
  the pair-law bridge `condExp_indicator_eq_of_pair_law_eq` fed by `Contractable.pairLaw_eq`.
* `Contractable.condExp_indicator_tailProcess_eq` — the same equality (with `k = 0`) conditioning on
  the process **tail σ-algebra** `tailProcess X`, obtained from the future-level form by the
  conditional-expectation tower (`condExp_condExp_of_le`).

The second is the "extreme members agree on the tail" step. Notably it avoids the reverse-martingale
(Lévy downward) machinery the reference's Kallenberg route uses: the tower property over
`tailProcess X ≤ σ(tail-as-RV)` reaches the same conclusion directly.

The supporting inequalities `tailFamily_le_comap_shift` / `tailProcess_le_comap_shift` (a process
tail σ-algebra sits below the σ-algebra of the shifted tail viewed as one random variable) are
general tail-σ-algebra facts; they are kept here, next to their only consumer, rather than in
`Process/Tail.lean` whose in-flight changes they would otherwise overlap.

Adapted from `cameronfreer/exchangeability` (`DeFinetti/ViaMartingale/CondExpConvergence.lean`,
`condexp_convergence` and `extreme_members_equal_on_tail_via_tower`, pin
`e0532e59ceff23edab44dda9ab0655debbc9cc22`).
-/

public section

noncomputable section

open MeasureTheory

namespace TauCeti

namespace Probability

variable {Ω α : Type*} [MeasurableSpace Ω] [MeasurableSpace α]

omit [MeasurableSpace Ω] in
/-- The future σ-algebra `tailFamily X r` is contained in the σ-algebra generated by the `r`-shifted
tail viewed as a single random variable `ω ↦ (X (r + ·) ω)`: each coordinate `X j` with `r ≤ j` is a
coordinate of that tail. -/
theorem tailFamily_le_comap_shift (X : ℕ → Ω → α) (r : ℕ) :
    tailFamily X r ≤ MeasurableSpace.comap (fun ω n => X (r + n) ω) inferInstance := by
  rw [tailFamily_eq_iSup_comap]
  refine iSup_le fun jk => ?_
  have hXj : X jk.1 = (fun f : ℕ → α => f (jk.1 - r)) ∘ fun ω n => X (r + n) ω := by
    funext ω
    simp only [Function.comp_apply]
    rw [show r + (jk.1 - r) = jk.1 from by have := jk.2; omega]
  rw [hXj, ← MeasurableSpace.comap_comp]
  exact MeasurableSpace.comap_mono (measurable_pi_apply (jk.1 - r)).comap_le

omit [MeasurableSpace Ω] in
/-- The process tail σ-algebra is contained in the σ-algebra of the `r`-shifted tail random
variable `ω ↦ (X (r + ·) ω)`. -/
theorem tailProcess_le_comap_shift (X : ℕ → Ω → α) (r : ℕ) :
    tailProcess X ≤ MeasurableSpace.comap (fun ω n => X (r + n) ω) inferInstance :=
  (tailProcess_le_tailFamily X r).trans (tailFamily_le_comap_shift X r)

/-- **Conditional law of a future coordinate.** For a contractable process and `k ≤ m`, the
conditional expectation of `𝟙_B ∘ X m` given the future tail (as the single random variable
`ω ↦ (X (m+1+·) ω)`) equals that of `𝟙_B ∘ X k`. This is the pair-law bridge
`condExp_indicator_eq_of_pair_law_eq` fed by the contractability pair-law
`Contractable.pairLaw_eq`. -/
theorem Contractable.condExp_indicator_future_eq {μ : Measure Ω} [IsFiniteMeasure μ]
    {X : ℕ → Ω → α} (hX : Contractable μ X) (hX_meas : ∀ n, Measurable (X n)) {k m : ℕ} (hk : k ≤ m)
    {B : Set α} (hB : MeasurableSet B) :
    μ[Set.indicator B (fun _ => (1 : ℝ)) ∘ X m |
        MeasurableSpace.comap (fun ω n => X (m + 1 + n) ω) inferInstance]
      =ᵐ[μ] μ[Set.indicator B (fun _ => (1 : ℝ)) ∘ X k |
        MeasurableSpace.comap (fun ω n => X (m + 1 + n) ω) inferInstance] :=
  TauCeti.MeasureTheory.condExp_indicator_eq_of_pair_law_eq (X m) (X k) (fun ω n => X (m + 1 + n) ω)
    (hX_meas m) (hX_meas k) (measurable_pi_lambda _ fun n => hX_meas (m + 1 + n))
    (hX.pairLaw_eq (j := m) (k := k) (g := fun n => m + 1 + n)
      (fun n => (hX_meas n).aemeasurable) (fun a b hab => by dsimp only; omega)
      (by omega) (by omega)) hB

/-- **Extreme members agree on the tail.** For a contractable process, the conditional expectation
of `𝟙_B ∘ X m` given the process tail σ-algebra `tailProcess X` equals that of `𝟙_B ∘ X 0`. Obtained
from `Contractable.condExp_indicator_future_eq` (with `k = 0`) by the conditional-expectation tower,
using `tailProcess X ≤ σ(X (m+1+·))`. -/
theorem Contractable.condExp_indicator_tailProcess_eq {μ : Measure Ω} [IsFiniteMeasure μ]
    {X : ℕ → Ω → α} (hX : Contractable μ X) (hX_meas : ∀ n, Measurable (X n)) (m : ℕ)
    {B : Set α} (hB : MeasurableSet B) :
    μ[Set.indicator B (fun _ => (1 : ℝ)) ∘ X m | tailProcess X]
      =ᵐ[μ] μ[Set.indicator B (fun _ => (1 : ℝ)) ∘ X 0 | tailProcess X] := by
  set Z : Ω → ℕ → α := fun ω n => X (m + 1 + n) ω with hZ
  have hZ_meas : Measurable Z := measurable_pi_lambda _ fun n => hX_meas (m + 1 + n)
  -- `tailProcess X ≤ σ(Z)` from the general `tailProcess_le_comap_shift`.
  have htail_le :
      tailProcess X ≤ MeasurableSpace.comap Z (inferInstance : MeasurableSpace (ℕ → α)) := by
    rw [hZ]; exact tailProcess_le_comap_shift X (m + 1)
  have hZ_le : MeasurableSpace.comap Z (inferInstance : MeasurableSpace (ℕ → α))
      ≤ (inferInstance : MeasurableSpace Ω) :=
    hZ_meas.comap_le
  haveI : IsFiniteMeasure (μ.trim hZ_le) := isFiniteMeasure_trim hZ_le
  -- The future-level equality (`k = 0`).
  have hP5 := hX.condExp_indicator_future_eq hX_meas (Nat.zero_le m) hB
  rw [← hZ] at hP5
  -- Tower: conditioning `μ[· | σ(Z)]` then on `tailProcess X` collapses to `μ[· | tailProcess X]`.
  have htower : ∀ g : Ω → ℝ,
      μ[μ[g | MeasurableSpace.comap Z (inferInstance : MeasurableSpace (ℕ → α))] | tailProcess X]
        =ᵐ[μ] μ[g | tailProcess X] :=
    fun g => condExp_condExp_of_le (μ := μ) htail_le hZ_le
  exact (htower _).symm.trans ((condExp_congr_ae hP5).trans (htower _))

end Probability

end TauCeti
